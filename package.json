{
  "name": "trackros",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "node scripts/ensure-next-cache.mjs",
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "audit": "npm audit --audit-level=high",
