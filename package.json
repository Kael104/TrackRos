    "gen:types": "supabase gen types typescript --schema public --linked > types/database.types.ts"
  },
  "dependencies": {
    "@google/generative-ai": "0.24.1",
    "@supabase/supabase-js": "2.110.2",
    "date-fns": "4.4.0",
    "dotenv": "17.4.2",
    "next": "15.5.19",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "server-only": "0.0.1",
    "zod": "3.25.76",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.2",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "22.20.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "4.7.0",
    "eslint": "9.39.4",
    "eslint-config-next": "15.5.19",
    "jsdom": "26.1.0",
    "tailwindcss": "4.3.2",
    "typescript": "5.9.3",
    "vitest": "3.2.6"
  },
