# Gemini API key for food nutrient lookups (server-only)
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase project credentials (Settings → API in the dashboard)
# Server-only — never expose the service role key to the browser.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# HTTP Basic Auth gate (required in production; optional in development)
APP_BASIC_AUTH_USER=trackros
APP_BASIC_AUTH_PASSWORD=change_me_to_a_strong_password

# Allowed origin for Server Actions CSRF checks (host only, e.g. trackros.vercel.app)
# Optional in development; set in production when deployed behind a custom domain.
APP_ALLOWED_ORIGIN=
