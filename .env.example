# Gemini API key for food nutrient lookups
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase project credentials (Settings → API in the dashboard)
# Use the Project URL and the "anon" "public" key (long JWT starting with eyJ...)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
